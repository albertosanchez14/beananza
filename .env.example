# Public browser origin used for server CORS/WebSocket origin checks.
# Local/dev compose can leave this empty.
PUBLIC_ORIGIN=

# Redis settings.
REDIS_PASSWORD=change-me
REDIS_DB=0

# Uploaded assets.
# docker-compose.local.yml overrides S3 settings to local MinIO.
# For production, point these S3 settings at your object store.
STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=fra1
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_ACL=public-read

# Host ports exposed by the compose overrides.
HTTP_PORT=80
HTTPS_PORT=443
