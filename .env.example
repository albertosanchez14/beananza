# Images used by docker-compose.yml when running without the dev build override.
GAME_CLIENT_IMAGE=ghcr.io/you/card-game-client
GAME_SERVER_IMAGE=ghcr.io/you/card-game-server
APP_TAG=latest

# Public browser origin used for server CORS/WebSocket origin checks.
# Local/dev compose can leave this empty.
PUBLIC_ORIGIN=

# Redis settings.
REDIS_PASSWORD=change-me
REDIS_DB=0

# Uploaded assets.
# docker-compose.yml uses local storage; docker-compose.prod.yml switches to S3.
MAX_AVATAR_UPLOAD_BYTES=2097152
AVATAR_UPLOAD_PREFIX=avatars
S3_BUCKET=
S3_REGION=fra1
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_ACL=public-read

# Host ports exposed by the compose overrides.
HTTP_PORT=80
HTTPS_PORT=443
