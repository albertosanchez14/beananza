# Environment Variables
SERVER_HOST=localhost
SERVER_PORT=8080

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info

# WebSocket Configuration
READ_BUFFER_SIZE=1024
WRITE_BUFFER_SIZE=1024
# Per-client outbound message buffer (number of messages); default 256
WS_SEND_BUFFER_SIZE=256
# Token-bucket rate limiter: sustained messages/sec and burst size
WS_RATE_LIMIT=10
WS_RATE_BURST=30

# CORS — comma-separated list of allowed WebSocket origins
# Leave empty to allow all origins (not recommended for production)
ALLOWED_ORIGINS=https://example.com

# Asset upload storage
# local stores uploads under LOCAL_OBJECT_DIR and serves LOCAL_PUBLIC_BASE_URL.
# s3 uses the S3-compatible API, including DigitalOcean Spaces.
STORAGE_BACKEND=local
MAX_AVATAR_UPLOAD_BYTES=2097152
AVATAR_UPLOAD_PREFIX=avatars
LOCAL_OBJECT_DIR=./uploads
LOCAL_PUBLIC_BASE_URL=/user-assets
S3_BUCKET=
S3_REGION=fra1
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_ACL=public-read

# Game config
GAME_CONFIG_PATH=game.yaml

# Timeout for disconnection
LOBBY_RESET_SECS=30
DISCONNECT_TIMEOUT_SECS=60
