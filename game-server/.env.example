# Environment Variables
SERVER_HOST=localhost
SERVER_PORT=8080

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info

# WebSocket Configuration
READ_BUFFER_SIZE=1024
WRITE_BUFFER_SIZE=1024
WS_SEND_BUFFER_SIZE=256
WS_RATE_LIMIT=10
WS_RATE_BURST=30

# CORS — comma-separated list of allowed WebSocket origins
# An empty slice disables the check.
ALLOWED_ORIGINS=https://example.com, https://example2.com

# Game config
CARDS_CONFIG_PATH=cards.yaml
CARDS_PER_TURN=2
MAX_NUMBER_PLAYERS=5
MIN_NUMBER_PLAYERS=3
MAX_RESHUFFLES=3
CARDS_PER_DRAW=3

# Timeout for disconnection
LOBBY_RESET_SECS=30
DISCONNECT_TIMEOUT_SECS=60
